{
  "name": "github-copilot-usage",
  "displayName": "GitHub Copilot Usage",
  "version": "0.4.2",
  "description": "Show GitHub Copilot Premium requests usage in the status bar.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "github",
    "quota",
    "status-bar",
    "usage",
    "vscode",
    "vscode-extension"
  ],
  "license": "MIT",
  "author": "euxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/euxx/github-copilot-usage"
  },
  "publisher": "euxx",
  "main": "./src/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run ci",
    "ci": "npm run syntax && npm run lint && npm run format:check && npm run test",
    "test": "vitest run",
    "syntax": "node -e \"for(const f of require('fs').readdirSync('src').filter(n=>n.endsWith('.js')))require('child_process').execSync('node --check src/'+f,{stdio:'inherit'})\"",
    "lint": "oxlint --deny-warnings src/ tests/",
    "lint:fix": "oxlint --deny-warnings src/ tests/ --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "package": "npx @vscode/vsce package --no-dependencies",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "vitest": "latest"
  },
  "lint-staged": {
    "*.{js,html,css,md,yml,yaml,json}": [
      "oxfmt --write"
    ],
    "*.js": [
      "oxlint --deny-warnings"
    ]
  },
  "contributes": {
    "commands": [
      {
        "command": "githubCopilotUsage.refresh",
        "title": "Copilot Usage: Refresh Now"
      },
      {
        "command": "githubCopilotUsage.signIn",
        "title": "Copilot Usage: Sign in with GitHub"
      }
    ],
    "configuration": {
      "title": "GitHub Copilot Usage",
      "properties": {
        "githubCopilotUsage.refreshIntervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "order": 0,
          "description": "Auto-refresh interval in minutes."
        },
        "githubCopilotUsage.threshold.enabled": {
          "type": "boolean",
          "default": true,
          "order": 0,
          "description": "Enable warning/critical threshold coloring in the status bar."
        },
        "githubCopilotUsage.threshold.warning": {
          "type": "number",
          "default": 75,
          "minimum": 1,
          "maximum": 100,
          "order": 1,
          "description": "Usage percentage at which the status bar text turns yellow."
        },
        "githubCopilotUsage.threshold.critical": {
          "type": "number",
          "default": 90,
          "minimum": 1,
          "maximum": 100,
          "order": 2,
          "description": "Usage percentage at which the status bar text turns red."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  }
}
